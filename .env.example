# ─────────────────────────────────────────────────────────────
#  2b2t Highway Surveillance — environment configuration
#  Copy to `.env` and fill in your own values. NEVER commit .env.
#  Every value has a default in config.js; only override what you need.
# ─────────────────────────────────────────────────────────────

# ── Minecraft / hybrid model ──
# The mineflayer monitor connects to a LOCAL ZenithProxy endpoint that holds
# the real 2b2t session. Point it at that local port (offline auth).
SERVER_HOST=127.0.0.1
SERVER_PORT=25571
SERVER_AUTH=offline
SERVER_VERSION=1.21.4          # MUST match your ZenithProxy build version
MONITOR_IGN=MonitorBot         # shared spectator identity (a real MC IGN)
MONITOR_VIEW_DISTANCE=short

# ── Owner / player lists ──
OWNER_IGN=YourIGN
WHITELIST=                     # comma-separated IGNs that never trigger alerts
WATCHLIST=                     # comma-separated IGNs that DO trigger priority alerts
PROXY_WHITELIST=YourIGN        # your account(s) allowed to drive the bots

# ── Discord notifications ──
DISCORD_WEBHOOK_URL=           # https://discord.com/api/webhooks/...  (leave blank to disable)
DISCORD_SIGHTING_ALERTS=off    # off | exit | all

# ── Fleet / public host ──
FLEET_BASE_PORT=25571
PUBLIC_HOST=YOUR_SERVER_IP     # public IP/host shown in the "IN THE SERVER" ping

# ── Dashboard ──
DASHBOARD_PORT=3000
DASHBOARD_HOST=0.0.0.0
TRUST_PROXY=false              # true only when behind a reverse proxy
# Bootstraps the FIRST dashboard user on initial run (no users yet). If password
# is omitted a random one is generated and printed to the console once.
ADMIN_USER=owner
ADMIN_PASSWORD=change-me

# ── Proxies (Webshare SOCKS5) ──
WEBSHARE_API_KEY=              # Webshare account API key (optional)
WEBSHARE_PROXY_LIST_URL=       # plan-specific proxy list download URL (optional)
PROXY_MAX_LATENCY_MS=250
PROXY_PREFER_COUNTRIES=US,CA

# ── Wealth intel (2b2t.vc) ──
WEALTH_ENABLED=true
# Many advanced scoring knobs (WEALTH_W_*, TTLs, refs) exist in config.js — override only if needed.

# ── Logging ──
LOG_LEVEL=info                 # error | warn | info | debug
ACTIVITY_RETENTION_DAYS=0      # 0 = keep forever
